          "name": "Checkout (from cart session)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sessionId\": \"{{sessionId}}\",\n  \"email\": \"buyer@example.com\",\n  \"promoCode\": \"SAVE20\",\n  \"deliveryFee\": 15\n}"
