{
  "info": {
    "_postman_id": "a1b2c3d4-shop-co-backend",
    "name": "SHOP.CO Backend (NestJS + TypeORM)",
    "description": "Figma SHOP.CO backend. **Auth:** `POST /auth/login` → `access_token` ni `accessToken` o‘zgaruvchisiga yozing. Admin **POST/PATCH/DELETE** so‘rovlarida header: `Authorization: Bearer {{accessToken}}`. Super admin: `superadmin@shop.co` / `1234` (birinchi ishga tushishda yaratiladi). **GET** lar token talab qilmaydi.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://shop-backend-production-862d.up.railway.app/api" },
    { "key": "categoryId", "value": "1" },
    { "key": "productId", "value": "1" },
    { "key": "variantId", "value": "1" },
    { "key": "reviewId", "value": "1" },
    { "key": "cartItemId", "value": "1" },
    { "key": "orderId", "value": "1" },
    { "key": "subscriberId", "value": "1" },
    { "key": "sessionId", "value": "" },
    { "key": "accessToken", "value": "" }
  ],
  "item": [
    {
      "name": "Root",
      "item": [
        {
          "name": "API info",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register (user)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"buyer@example.com\",\n  \"password\": \"secret12\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "Login superadmin",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"superadmin@shop.co\",\n  \"password\": \"1234\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/auth/me"
          }
        },
        {
          "name": "Create admin (superadmin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@shop.co\",\n  \"password\": \"adminpass12\"\n}"
            },
            "url": "{{baseUrl}}/auth/admins"
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "List categories",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/categories"
          }
        },
        {
          "name": "Create category",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"T-shirts\"\n}"
            },
            "url": "{{baseUrl}}/categories"
          }
        },
        {
          "name": "Get category by id",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/categories/{{categoryId}}"
          }
        },
        {
          "name": "Update category",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"T-Shirts\"\n}"
            },
            "url": "{{baseUrl}}/categories/{{categoryId}}"
          }
        },
        {
          "name": "Delete category",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/categories/{{categoryId}}"
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "List products (filters)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/products?page=1&limit=12&sort=newest&categoryId=&minPrice=&maxPrice=&color=&size=&style="
          }
        },
        {
          "name": "List products — sort price_asc",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/products?sort=price_asc&page=1&limit=12"
          }
        },
        {
          "name": "List products — sort popular",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/products?sort=popular&page=1&limit=12"
          }
        },
        {
          "name": "New arrivals (4)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/products/new-arrivals"
          }
        },
        {
          "name": "Top selling (4)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/products/top-selling"
          }
        },
        {
          "name": "Create product",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"T-shirt with Tape Details\",\n  \"description\": \"Comfortable cotton tee.\",\n  \"price\": 260,\n  \"discountPercentage\": 20,\n  \"rating\": 4.5,\n  \"stockQuantity\": 100,\n  \"images\": [\n    \"https://example.com/img1.jpg\"\n  ],\n  \"style\": \"Casual\",\n  \"categoryId\": null\n}"
            },
            "url": "{{baseUrl}}/products"
          }
        },
        {
          "name": "Get product by id",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/products/{{productId}}"
          }
        },
        {
          "name": "Related products",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/products/{{productId}}/related"
          }
        },
        {
          "name": "Get product reviews",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/products/{{productId}}/reviews"
          }
        },
        {
          "name": "Add review to product",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userName\": \"Alex\",\n  \"rating\": 5,\n  \"comment\": \"Great quality!\",\n  \"isVerified\": true\n}"
            },
            "url": "{{baseUrl}}/products/{{productId}}/reviews"
          }
        },
        {
          "name": "Update product",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"T-shirt with Tape Details (updated)\",\n  \"stockQuantity\": 80\n}"
            },
            "url": "{{baseUrl}}/products/{{productId}}"
          }
        },
        {
          "name": "Delete product",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/products/{{productId}}"
          }
        }
      ]
    },
    {
      "name": "Product variants",
      "item": [
        {
          "name": "List variants",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/products/{{productId}}/variants"
          }
        },
        {
          "name": "Create variant",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"color\": \"Green\",\n  \"size\": \"Large\",\n  \"stockQuantity\": 25\n}"
            },
            "url": "{{baseUrl}}/products/{{productId}}/variants"
          }
        },
        {
          "name": "Get variant",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/products/{{productId}}/variants/{{variantId}}"
          }
        },
        {
          "name": "Update variant",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"color\": \"Blue\",\n  \"stockQuantity\": 30\n}"
            },
            "url": "{{baseUrl}}/products/{{productId}}/variants/{{variantId}}"
          }
        },
        {
          "name": "Delete variant",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/products/{{productId}}/variants/{{variantId}}"
          }
        }
      ]
    },
    {
      "name": "Reviews",
      "item": [
        {
          "name": "Featured testimonials (homepage)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/reviews"
          }
        },
        {
          "name": "All reviews",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/reviews?mode=all"
          }
        },
        {
          "name": "Create review (optional productId)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userName\": \"Sarah M.\",\n  \"rating\": 5,\n  \"comment\": \"Love the quality!\",\n  \"isVerified\": true,\n  \"isFeatured\": true,\n  \"reviewedAt\": \"2026-05-01\",\n  \"productId\": null\n}"
            },
            "url": "{{baseUrl}}/reviews"
          }
        },
        {
          "name": "Get review by id",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/reviews/{{reviewId}}"
          }
        },
        {
          "name": "Update review",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"isFeatured\": true,\n  \"rating\": 5\n}"
            },
            "url": "{{baseUrl}}/reviews/{{reviewId}}"
          }
        },
        {
          "name": "Delete review",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/reviews/{{reviewId}}"
          }
        }
      ]
    },
    {
      "name": "Styles",
      "item": [
        {
          "name": "List dress styles",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/styles"
          }
        }
      ]
    },
    {
      "name": "Cart",
      "item": [
        {
          "name": "Add to cart (new session in response)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"quantity\": 1,\n  \"selectedSize\": \"Large\",\n  \"selectedColor\": \"Green\"\n}"
            },
            "url": "{{baseUrl}}/cart"
          }
        },
        {
          "name": "Add to cart (existing session in body)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"quantity\": 2,\n  \"selectedSize\": \"Large\",\n  \"selectedColor\": \"Green\",\n  \"sessionId\": \"{{sessionId}}\"\n}"
            },
            "url": "{{baseUrl}}/cart"
          }
        },
        {
          "name": "Add to cart (header x-cart-session)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-cart-session", "value": "{{sessionId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"quantity\": 1,\n  \"selectedSize\": \"Medium\",\n  \"selectedColor\": \"Black\"\n}"
            },
            "url": "{{baseUrl}}/cart"
          }
        },
        {
          "name": "Get cart (query sessionId)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/cart?sessionId={{sessionId}}"
          }
        },
        {
          "name": "Get cart (header x-cart-session)",
          "request": {
            "method": "GET",
            "header": [{ "key": "x-cart-session", "value": "{{sessionId}}" }],
            "url": "{{baseUrl}}/cart"
          }
        },
        {
          "name": "Update cart item quantity",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-cart-session", "value": "{{sessionId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quantity\": 3\n}"
            },
            "url": "{{baseUrl}}/cart/{{cartItemId}}?sessionId={{sessionId}}"
          }
        },
        {
          "name": "Remove cart item",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "x-cart-session", "value": "{{sessionId}}" }],
            "url": "{{baseUrl}}/cart/{{cartItemId}}"
          }
        }
      ]
    },
    {
      "name": "Orders",
