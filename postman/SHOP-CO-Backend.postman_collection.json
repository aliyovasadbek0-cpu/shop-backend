            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"paid\",\n  \"email\": \"buyer@example.com\"\n}"
            },
            "url": "{{baseUrl}}/orders/{{orderId}}"
          }
        },
        {
          "name": "Delete order",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/orders/{{orderId}}"
          }
        }
      ]
    },
