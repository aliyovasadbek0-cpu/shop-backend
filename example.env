# Server
PORT=3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=shop_co

# TypeORM: true faqat developmentda (productionda migration ishlating)
TYPEORM_SYNC=true

# JWT (productionda JWT_SECRET uzun va tasodifiy bo‘lsin)
JWT_SECRET=dev-secret-change-in-production
JWT_EXPIRES_DAYS=7

# Super admin (agar bazada super_admin bo‘lmasa, ishga tushganda yaratiladi)
SUPER_ADMIN_EMAIL=superadmin@shop.co
SUPER_ADMIN_PASSWORD=1234

# Checkout
DEFAULT_DELIVERY_FEE=15
# Promo: kod=foiz (masalan SAVE20 -> 20% chegirma)
PROMO_SAVE20_PERCENT=20
PROMO_WELCOME10_PERCENT=10

# API bazaviy URL: http://localhost:3000/api (GET /api — loyiha haqida qisqa JSON)
